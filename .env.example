# Healia Environment Variables

# Google Gemini API Key (Google Vertex AI)
# Get your key from: https://aistudio.google.com/app/apikey
# In production, this is injected via Google Cloud Secret Manager
VITE_GEMINI_API_KEY=

# Optional: Google Cloud Project ID (for logging/monitoring)
# VITE_GCP_PROJECT_ID=your-gcp-project-id

# Optional: Healia Smart Contract Address on Sepolia
# VITE_CONTRACT_ADDRESS=0x...

# Optional: Sepolia RPC URL
# VITE_SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/your-infura-key
